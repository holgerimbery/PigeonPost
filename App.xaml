<Application
    x:Class="PigeonPost.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls"/>
            </ResourceDictionary.MergedDictionaries>

            <!--
                Theme-adaptive semantic brushes — GitHub Primer colour palette.
                Identical keys to what MainViewModel.RefreshStatusColors() and
                LogEntry.LevelBrush look up at runtime so C# code and XAML always
                get the correct colour for the active Windows light/dark mode.

                Palette source: GitHub Primer design system
                  Light — github.com/primer/primitives (light theme)
                  Dark  — github.com/primer/primitives (dark theme)
            -->
            <ResourceDictionary.ThemeDictionaries>

                <!-- ── GitHub Light ── -->
                <ResourceDictionary x:Key="Light">
                    <!-- App title — Copilot / GitHub "done" purple -->
                    <SolidColorBrush x:Key="AppTitleBrush"      Color="#8250df"/>
                    <!-- Status indicator (header ellipse + tray icon) -->
                    <SolidColorBrush x:Key="StatusRunningBrush" Color="#1a7f37"/>
                    <SolidColorBrush x:Key="StatusPausedBrush"  Color="#9a6700"/>
                    <SolidColorBrush x:Key="StatusErrorBrush"   Color="#cf222e"/>
                    <!-- Activity-log level labels -->
                    <SolidColorBrush x:Key="LogFileBrush"       Color="#8250df"/>
                    <SolidColorBrush x:Key="LogClipboardBrush"  Color="#0969da"/>
                    <SolidColorBrush x:Key="LogWarnBrush"       Color="#9a6700"/>
                    <SolidColorBrush x:Key="LogErrorBrush"      Color="#cf222e"/>
                    <SolidColorBrush x:Key="LogSuccessBrush"    Color="#1a7f37"/>
                    <SolidColorBrush x:Key="LogInfoBrush"       Color="#57606a"/>
                </ResourceDictionary>

                <!-- ── GitHub Dark ── -->
                <ResourceDictionary x:Key="Dark">
                    <!-- App title — Copilot / GitHub "done" purple (lighter for dark bg) -->
                    <SolidColorBrush x:Key="AppTitleBrush"      Color="#bc8cff"/>
                    <!-- Status indicator (header ellipse + tray icon) -->
                    <SolidColorBrush x:Key="StatusRunningBrush" Color="#3fb950"/>
                    <SolidColorBrush x:Key="StatusPausedBrush"  Color="#e3b341"/>
                    <SolidColorBrush x:Key="StatusErrorBrush"   Color="#f85149"/>
                    <!-- Activity-log level labels -->
                    <SolidColorBrush x:Key="LogFileBrush"       Color="#bc8cff"/>
                    <SolidColorBrush x:Key="LogClipboardBrush"  Color="#58a6ff"/>
                    <SolidColorBrush x:Key="LogWarnBrush"       Color="#e3b341"/>
                    <SolidColorBrush x:Key="LogErrorBrush"      Color="#f85149"/>
                    <SolidColorBrush x:Key="LogSuccessBrush"    Color="#3fb950"/>
                    <SolidColorBrush x:Key="LogInfoBrush"       Color="#8b949e"/>
                </ResourceDictionary>

            </ResourceDictionary.ThemeDictionaries>

            <!-- Reusable card style for stat tiles & content sections -->
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="16,12"/>
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <Style x:Key="StatValueStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="22"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="0,0,0,2"/>
            </Style>

            <Style x:Key="StatLabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Opacity" Value="0.7"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
