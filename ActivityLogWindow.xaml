<Window
    x:Class="PigeonPost.ActivityLogWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:PigeonPost.Models"
    xmlns:conv="using:PigeonPost.Converters"
    Title="Activity Log — PigeonPost">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Padding="24" RowSpacing="12">
        <!--
            HexColorConverter must live on a FrameworkElement (Grid), not on Window,
            because the WinUI 3 XAML compiler passes `this` (Window) to SetConverterLookupRoot
            which expects a FrameworkElement — same constraint as in MainWindow.
        -->
        <Grid.Resources>
            <conv:HexColorConverter x:Key="HexColorConverter"/>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header: title + badge + Clear ── -->
        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Activity Log" FontSize="18" FontWeight="SemiBold"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <Border CornerRadius="10" Padding="7,1"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        Visibility="{x:Bind ViewModel.LogCountVisible, Mode=OneWay}">
                    <TextBlock Text="{x:Bind ViewModel.LogCount, Mode=OneWay}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center"/>
                </Border>
            </StackPanel>
            <Button Content="Clear" HorizontalAlignment="Right"
                    Command="{x:Bind ViewModel.ClearLogCommand}"/>
        </Grid>

        <!-- ── Log list ── -->
        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.LogEntries}"
                  SelectionMode="None"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                  CornerRadius="4" Padding="4">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:LogEntry">
                    <Grid ColumnSpacing="12" Padding="4,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Bind TimeText}" Opacity="0.5"
                                   FontFamily="Consolas" FontSize="12"/>
                        <!--
                            Must use {Binding} (not {x:Bind}) with HexColorConverter here —
                            same reason as in MainWindow: {x:Bind Converter=} generates
                            SetConverterLookupRoot(FrameworkElement) but Window is not a
                            FrameworkElement in WinUI 3, causing a CS1503 compile error.
                        -->
                        <TextBlock Grid.Column="1" Text="{x:Bind LevelLabel}"
                                   Foreground="{Binding LevelColor, Converter={StaticResource HexColorConverter}}"
                                   FontFamily="Consolas" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="{x:Bind Message}"
                                   TextWrapping="Wrap" FontSize="12"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>
