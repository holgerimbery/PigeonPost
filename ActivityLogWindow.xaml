<Window
    x:Class="PigeonPost.ActivityLogWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:PigeonPost.Models"
    xmlns:conv="using:PigeonPost.Converters"
    Title="Activity Log — PigeonPost">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Padding="24" RowSpacing="8">
        <Grid.Resources>
            <conv:HexColorConverter x:Key="HexColorConverter"/>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Row 0: header (title + badge + Clear) -->
            <RowDefinition Height="Auto"/>
            <!-- Row 1: filter bar -->
            <RowDefinition Height="*"/>
            <!-- Row 2: log list -->
        </Grid.RowDefinitions>

        <!-- ── Header: title + badge + Clear ── -->
        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Activity Log" FontSize="18" FontWeight="SemiBold"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <!-- Badge managed from code-behind; shows "filtered / total" when a filter is active -->
                <Border x:Name="LogBadge" CornerRadius="10" Padding="7,1"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        Visibility="Collapsed">
                    <TextBlock x:Name="LogBadgeText"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center"/>
                </Border>
            </StackPanel>
            <Button Content="Clear" HorizontalAlignment="Right"
                    Command="{x:Bind ViewModel.ClearLogCommand}"/>
        </Grid>

        <!-- ── Filter bar ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <!-- Level toggle buttons on the left -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <ToggleButton x:Name="FilterInfo"      Content="INFO"      IsChecked="True" Tag="Info"
                              Padding="8,3" FontFamily="Consolas" FontSize="11"
                              Checked="LevelToggle_Changed" Unchecked="LevelToggle_Changed"/>
                <ToggleButton x:Name="FilterSuccess"   Content="OK"        IsChecked="True" Tag="Success"
                              Padding="8,3" FontFamily="Consolas" FontSize="11"
                              Checked="LevelToggle_Changed" Unchecked="LevelToggle_Changed"/>
                <ToggleButton x:Name="FilterWarn"      Content="WARN"      IsChecked="True" Tag="Warn"
                              Padding="8,3" FontFamily="Consolas" FontSize="11"
                              Checked="LevelToggle_Changed" Unchecked="LevelToggle_Changed"/>
                <ToggleButton x:Name="FilterError"     Content="ERROR"     IsChecked="True" Tag="Error"
                              Padding="8,3" FontFamily="Consolas" FontSize="11"
                              Checked="LevelToggle_Changed" Unchecked="LevelToggle_Changed"/>
                <ToggleButton x:Name="FilterFile"      Content="FILE"      IsChecked="True" Tag="File"
                              Padding="8,3" FontFamily="Consolas" FontSize="11"
                              Checked="LevelToggle_Changed" Unchecked="LevelToggle_Changed"/>
                <ToggleButton x:Name="FilterClipboard" Content="CLIPBOARD" IsChecked="True" Tag="Clipboard"
                              Padding="8,3" FontFamily="Consolas" FontSize="11"
                              Checked="LevelToggle_Changed" Unchecked="LevelToggle_Changed"/>
            </StackPanel>
            <!-- Text search on the right -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <TextBox x:Name="SearchBox"
                         PlaceholderText="Search messages…"
                         Width="190"
                         TextChanged="SearchBox_TextChanged"/>
                <Button ToolTipService.ToolTip="Clear search"
                        Click="ClearSearch_Click">
                    <FontIcon Glyph="&#xE894;" FontSize="12"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ── Log list (bound to local FilteredEntries) ── -->
        <ListView Grid.Row="2"
                  ItemsSource="{x:Bind FilteredEntries}"
                  SelectionMode="None"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                  CornerRadius="4" Padding="4">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:LogEntry">
                    <Grid ColumnSpacing="12" Padding="4,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Bind TimeText}" Opacity="0.5"
                                   FontFamily="Consolas" FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind LevelLabel}"
                                   Foreground="{Binding LevelColor, Converter={StaticResource HexColorConverter}}"
                                   FontFamily="Consolas" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="{x:Bind Message}"
                                   TextWrapping="Wrap" FontSize="12"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>
