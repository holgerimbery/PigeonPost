<Window
    x:Class="PigeonPost.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Settings — PigeonPost">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Scrollable settings content ── -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20" Width="380" Padding="0,8,0,8">

                <!-- ── General ──────────────────────────────────────── -->
                <TextBlock Text="General" FontWeight="SemiBold" FontSize="14"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                <ToggleSwitch x:Name="AutostartSwitch"
                              Header="Start with Windows"
                              OffContent="" OnContent=""
                              MinWidth="0"/>

                <Rectangle Height="1" Margin="0,4"
                           Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Opacity="0.4"/>

                <!-- ── Files ────────────────────────────────────────── -->
                <TextBlock Text="Files" FontWeight="SemiBold" FontSize="14"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                <StackPanel Spacing="6">
                    <TextBlock Text="Save received files to" Opacity="0.7" FontSize="12"/>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="DownloadsFolderBox" Grid.Column="0"
                                 IsReadOnly="True" FontFamily="Consolas" FontSize="12"/>
                        <Button x:Name="BrowseButton" Grid.Column="1"
                                Content="Browse" VerticalAlignment="Bottom"
                                Click="BrowseButton_Click"/>
                    </Grid>
                </StackPanel>

                <Rectangle Height="1" Margin="0,4"
                           Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Opacity="0.4"/>

                <!-- ── Appearance ────────────────────────────────────── -->
                <TextBlock Text="Appearance" FontWeight="SemiBold" FontSize="14"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                <!--
                    Three theme options; selecting one applies the change immediately so the
                    user gets a live preview — Cancel reverts the theme to what it was before
                    the window was opened.
                -->
                <RadioButtons x:Name="ThemeRadios"
                              SelectionChanged="ThemeRadios_SelectionChanged">
                    <RadioButtons.Header>
                        <TextBlock Text="Theme" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    </RadioButtons.Header>
                    <RadioButton Content="☀️  Light"           Tag="Light"/>
                    <RadioButton Content="🌙  Dark"            Tag="Dark"/>
                    <RadioButton Content="🖥️  Follow Windows"  Tag="System"/>
                </RadioButtons>

                <Rectangle Height="1" Margin="0,4"
                           Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Opacity="0.4"/>

                <!-- ── Security ──────────────────────────────────────── -->
                <TextBlock Text="Security" FontWeight="SemiBold" FontSize="14"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                <ToggleSwitch x:Name="RequireAuthSwitch"
                              Header="Require bearer token authentication"
                              OffContent="" OnContent=""
                              MinWidth="0"/>

                <StackPanel Spacing="6">
                    <TextBlock Text="Bearer token (send in Authorization header)" Opacity="0.7" FontSize="12"/>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="AuthTokenBox" Grid.Column="0"
                                 IsReadOnly="True" FontFamily="Consolas" FontSize="11"
                                 TextWrapping="NoWrap"/>
                        <Button x:Name="CopyTokenButton" Grid.Column="1"
                                ToolTipService.ToolTip="Copy token to clipboard"
                                VerticalAlignment="Bottom"
                                Click="CopyTokenButton_Click">
                            <FontIcon Glyph="&#xE8C8;" FontSize="14"/>
                        </Button>
                        <Button x:Name="RegenerateTokenButton" Grid.Column="2"
                                Content="Regenerate"
                                VerticalAlignment="Bottom"
                                Click="RegenerateTokenButton_Click"/>
                    </Grid>
                </StackPanel>

                <Rectangle Height="1" Margin="0,4"
                           Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Opacity="0.4"/>

                <!-- ── Updates ──────────────────────────────────────── -->
                <TextBlock Text="Updates" FontWeight="SemiBold" FontSize="14"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                <StackPanel Spacing="8">
                    <Button x:Name="CheckUpdateButton"
                            Content="Check for Updates"
                            Click="CheckUpdateButton_Click"/>
                    <TextBlock x:Name="UpdateStatusText"
                               FontSize="12" Opacity="0.8"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Save / Cancel footer ── -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="Cancel"
                    Click="CancelButton_Click"/>
            <Button x:Name="SaveButton" Content="Save"
                    Style="{ThemeResource AccentButtonStyle}"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
