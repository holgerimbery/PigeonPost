<Window
    x:Class="PigeonPost.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Settings — PigeonPost">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Scrollable settings content ── -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="6" Padding="0,4,0,4">

                <!-- ── General ──────────────────────────────────────── -->
                <Expander IsExpanded="False"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch">
                    <Expander.Header>
                        <TextBlock Text="General" FontWeight="SemiBold" FontSize="13"/>
                    </Expander.Header>
                    <StackPanel Spacing="16" Padding="4,8,4,8">
                        <ToggleSwitch x:Name="AutostartSwitch"
                                      Header="Start with Windows"
                                      OffContent="" OnContent=""
                                      MinWidth="0"/>
                    </StackPanel>
                </Expander>

                <!-- ── Files ────────────────────────────────────────── -->
                <Expander IsExpanded="False"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch">
                    <Expander.Header>
                        <TextBlock Text="Files" FontWeight="SemiBold" FontSize="13"/>
                    </Expander.Header>
                    <StackPanel Spacing="6" Padding="4,8,4,8">
                        <TextBlock Text="Save received files to" Opacity="0.7" FontSize="12"/>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="DownloadsFolderBox" Grid.Column="0"
                                     IsReadOnly="True" FontFamily="Consolas" FontSize="12"/>
                            <Button x:Name="BrowseButton" Grid.Column="1"
                                    Content="Browse" VerticalAlignment="Bottom"
                                    Click="BrowseButton_Click"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- ── Appearance ────────────────────────────────────── -->
                <!--
                    Three theme options; selecting one applies the change immediately so the
                    user gets a live preview — Cancel reverts the theme to what it was before
                    the window was opened.
                -->
                <Expander IsExpanded="False"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch">
                    <Expander.Header>
                        <TextBlock Text="Appearance" FontWeight="SemiBold" FontSize="13"/>
                    </Expander.Header>
                    <StackPanel Spacing="16" Padding="4,8,4,8">
                        <RadioButtons x:Name="ThemeRadios"
                                      SelectionChanged="ThemeRadios_SelectionChanged">
                            <RadioButtons.Header>
                                <TextBlock Text="Theme" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            </RadioButtons.Header>
                            <RadioButton Content="Light"           Tag="Light"/>
                            <RadioButton Content="Dark"            Tag="Dark"/>
                            <RadioButton Content="Follow Windows"  Tag="System"/>
                        </RadioButtons>
                    </StackPanel>
                </Expander>

                <!-- ── Security ──────────────────────────────────────── -->
                <Expander IsExpanded="False"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch">
                    <Expander.Header>
                        <TextBlock Text="Security" FontWeight="SemiBold" FontSize="13"/>
                    </Expander.Header>
                    <StackPanel Spacing="16" Padding="4,8,4,8">
                        <ToggleSwitch x:Name="RequireAuthSwitch"
                                      Header="Require bearer token authentication"
                                      OffContent="" OnContent=""
                                      MinWidth="0"/>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Bearer token (send in Authorization header)"
                                       Opacity="0.7" FontSize="12"/>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="AuthTokenBox" Grid.Column="0"
                                         IsReadOnly="True" FontFamily="Consolas" FontSize="11"
                                         TextWrapping="NoWrap"/>
                                <Button x:Name="CopyTokenButton" Grid.Column="1"
                                        ToolTipService.ToolTip="Copy token to clipboard"
                                        VerticalAlignment="Bottom"
                                        Click="CopyTokenButton_Click">
                                    <FontIcon Glyph="&#xE8C8;" FontSize="14"/>
                                </Button>
                                <Button x:Name="RegenerateTokenButton" Grid.Column="2"
                                        Content="Regenerate" VerticalAlignment="Bottom"
                                        Click="RegenerateTokenButton_Click"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Expander>

                <!-- ── Keep Awake ────────────────────────────────────────── -->
                <Expander IsExpanded="False"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch">
                    <Expander.Header>
                        <TextBlock Text="Keep Awake" FontWeight="SemiBold" FontSize="13"/>
                    </Expander.Header>
                    <StackPanel Spacing="12" Padding="4,8,4,8">
                        <ToggleSwitch x:Name="AllowKeepAwakeSwitch"
                                      Header="Allow peers to keep this PC awake"
                                      OffContent="" OnContent=""
                                      MinWidth="0"/>
                        <TextBlock Text="When enabled, only the peers listed below can send periodic pings to prevent the screensaver and display-off on this PC. If no ping arrives within 90 seconds, normal sleep behaviour is automatically restored."
                                   FontSize="11" Opacity="0.7" TextWrapping="Wrap"/>
                        <TextBlock Text="Allowed senders (one machine name per line)"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBox x:Name="SenderNamesBox"
                                 AcceptsReturn="True"
                                 Height="90"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 PlaceholderText="DESKTOP-ABC&#x0a;LAPTOP-XYZ"
                                 FontFamily="Consolas"
                                 FontSize="12"/>
                        <TextBlock Text="Leave empty to block all keep-awake requests even when the toggle above is on."
                                   FontSize="11" Opacity="0.7" TextWrapping="Wrap"/>
                    </StackPanel>
                </Expander>

                <!-- ── Network ───────────────────────────────────────────── -->
                <Expander IsExpanded="False"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch">
                    <Expander.Header>
                        <TextBlock Text="Network" FontWeight="SemiBold" FontSize="13"/>
                    </Expander.Header>
                    <StackPanel Spacing="12" Padding="4,8,4,8">
                        <ToggleSwitch x:Name="ExcludeVirtualAdaptersSwitch"
                                      Header="Exclude virtual network adapters"
                                      OffContent="" OnContent=""
                                      MinWidth="0"/>
                        <TextBlock Text="When enabled, Hyper-V, VMware, and VirtualBox virtual switch adapters are ignored when choosing the listen address and binding the HTTP server. Disable only if you intentionally want PigeonPost to listen on a virtual adapter IP."
                                   FontSize="11" Opacity="0.7" TextWrapping="Wrap"/>
                    </StackPanel>
                </Expander>

                <!-- ── Updates ──────────────────────────────────────────── -->
                <!--
                    UpdatesSection is hidden at runtime in the Store/MSIX build
                    (SettingsWindow.xaml.cs constructor, #if STORE_BUILD guard).
                    Updates are managed by the Microsoft Store in that channel.
                -->
                <Expander x:Name="UpdatesSection"
                          IsExpanded="False"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch">
                    <Expander.Header>
                        <TextBlock Text="Updates" FontWeight="SemiBold" FontSize="13"/>
                    </Expander.Header>
                    <StackPanel Spacing="16" Padding="4,8,4,8">
                        <ToggleSwitch x:Name="IncludeBetaSwitch"
                                      Header="Include beta releases"
                                      OffContent="" OnContent=""
                                      MinWidth="0"/>
                        <StackPanel Spacing="8">
                            <Button x:Name="CheckUpdateButton"
                                    Content="Check for Updates"
                                    Click="CheckUpdateButton_Click"/>
                            <TextBlock x:Name="UpdateStatusText"
                                       FontSize="12" Opacity="0.8"
                                       TextWrapping="Wrap"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </StackPanel>
                </Expander>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Save / Cancel footer ── -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="Cancel"
                    Click="CancelButton_Click"/>
            <Button x:Name="SaveButton" Content="Save"
                    Style="{ThemeResource AccentButtonStyle}"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
